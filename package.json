{
  "name": "fabulist",
  "productName": "Fabulist",
  "version": "0.1.0",
  "description": "AI-native writing studio powered by Claude Code — every document is a versioned, rewindable agent project",
  "license": "MIT",
  "author": "Mason Seale",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MasonLS/fabulist.git"
  },
  "homepage": "https://github.com/MasonLS/fabulist",
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "writing",
    "editor",
    "electron",
    "agent"
  ],
  "type": "module",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "install": "npm install --ignore-scripts && node node_modules/electron/install.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:regression": "vitest run --config tests/vitest.config.ts tests/regression",
    "start": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.172",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/literata": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "diff": "^9.0.0",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.4",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  }
}
